DB_USER=proy2
DB_PASSWORD=secret
DB_NAME=brickland
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false
DATABASE_URL=postgresql://proy2:secret@localhost:5432/brickland?schema=public
PORT=3000

# Proyecto 3: Prisma usa DATABASE_URL y el backend mantiene DB_* para pg Pool.
# Variables ORM_* son referencia documental; no activan sincronizacion automatica.
ORM_DIALECT=postgres
ORM_LOGGING=false
ORM_SYNC=false
